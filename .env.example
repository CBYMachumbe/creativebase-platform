# CreativeBase — Environment Variables
# Copy to .env and fill in all values. Never commit .env.

DATABASE_URL=postgresql://creativebase:localdev@localhost:5432/creativebase_dev
POSTGRES_USER=creativebase
POSTGRES_PASSWORD=localdev
POSTGRES_DB=creativebase_dev

REDIS_URL=redis://localhost:6379

# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_64_byte_hex
JWT_REFRESH_SECRET=CHANGE_ME_64_byte_hex_different
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

S3_ENDPOINT=http://localhost:9000
S3_REGION=af-south-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=creativebase-uploads
S3_BUCKET_PRIVATE=creativebase-private
CDN_URL=http://localhost:9000/creativebase-uploads

EMAIL_PROVIDER=smtp
SMTP_HOST=localhost
SMTP_PORT=1025
EMAIL_FROM=noreply@creativebase.co.za
EMAIL_FROM_NAME=CreativeBase

STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_CHANGE_ME
STRIPE_PRICE_CREATOR_BASIC_MONTHLY=price_CHANGE_ME
STRIPE_PRICE_CREATOR_PRO_MONTHLY=price_CHANGE_ME
STRIPE_PRICE_CREATOR_PRO_ANNUAL=price_CHANGE_ME
STRIPE_PRICE_CONTRACTOR_MONTHLY=price_CHANGE_ME
STRIPE_PRICE_CONTRACTOR_ANNUAL=price_CHANGE_ME

GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME

APP_URL=http://localhost:3000
API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

LAUNCH_FREE_TRIAL=true
FREE_TRIAL_LIMIT=500
FREE_TRIAL_MONTHS=3

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

NODE_ENV=development
PORT=3001
LOG_LEVEL=debug