{
  "name": "@creativebase/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.8", "@nestjs/core": "^10.3.8",
    "@nestjs/platform-express": "^10.3.8", "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3", "@nestjs/swagger": "^7.3.1",
    "@nestjs/throttler": "^5.1.2", "@nestjs/config": "^3.2.2",
    "@nestjs/schedule": "^4.0.2", "@prisma/client": "^5.14.0",
    "passport": "^0.7.0", "passport-jwt": "^4.0.1",
    "passport-google-oauth20": "^2.0.0", "bcrypt": "^5.1.1",
    "helmet": "^7.1.0", "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1", "ioredis": "^5.3.2",
    "stripe": "^15.7.0", "nodemailer": "^6.9.13",
    "zod": "^3.23.4", "reflect-metadata": "^0.2.2", "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2", "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.3.8", "prisma": "^5.14.0",
    "supertest": "^7.0.0", "jest": "^29.7.0",
    "ts-jest": "^29.1.4", "@types/jest": "^29.5.12",
    "ts-node": "^10.9.2", "@types/bcrypt": "^5.0.2",
    "@types/supertest": "^6.0.2"
  },
  "jest": {
    "moduleFileExtensions": ["js","json","ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": { "^.+\\.(t|j)s$": "ts-jest" },
    "collectCoverageFrom": ["**/*.(t|j)s","!**/*.spec.(t|j)s","!**/main.ts"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "coverageThreshold": { "global": { "lines": 80, "functions": 80, "branches": 75 } }
  },
  "prisma": { "seed": "ts-node prisma/seed.ts" }
}